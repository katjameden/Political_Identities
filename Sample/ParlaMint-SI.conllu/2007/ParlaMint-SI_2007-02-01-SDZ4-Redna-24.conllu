# newpar id = ParlaMint-SI_2007-02-01-SDZ4-Redna-24.ana.seg77
# lang = sl
# sent_id = ParlaMint-SI_2007-02-01-SDZ4-Redna-24.ana.seg77.1
# senti_3 = Positive
# senti_6 = mixed positive
